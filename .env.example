# Supabase (públicos - usar RLS no backend)
# Obtenha em: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Só para scripts (criar bucket, etc.). NUNCA use no app ou no front.
# Dashboard > Settings > API > service_role (secret)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mapbox (mapas no app cliente)
# Obtenha em: https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# Stripe (pagamentos / tokenização de cartões)
# Obtenha em: https://dashboard.stripe.com/apikeys (chave pública)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Edge Functions (Supabase Dashboard → Edge Functions → Secrets), não no app:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # Webhooks → endpoint …/functions/v1/stripe-webhook
# STRIPE_CONNECT_RETURN_URL=https://seu-dominio.com/conta/recebimentos
# STRIPE_CONNECT_REFRESH_URL=https://seu-dominio.com/conta/recebimentos

# Google Maps (opcional, Android/iOS)
# Obtenha em: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
