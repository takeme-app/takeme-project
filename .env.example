# ======================================================================
# Take Me — variáveis de ambiente (monorepo)
# ----------------------------------------------------------------------
# Copie este arquivo para `.env` na raiz do repositório e preencha os
# valores. Depois rode `npm run sync-env` para espelhar o arquivo
# para apps/cliente, apps/motorista e apps/admin.
#
# NUNCA commitar `.env` (já está em .gitignore).
# Variáveis `EXPO_PUBLIC_*` entram no bundle do app — coloque SOMENTE
# chaves públicas (anon, publishable, tokens restritos por URL/referrer).
# ======================================================================


# ======================================================================
# 1. Supabase — TODOS os apps (cliente, motorista, admin)
# ----------------------------------------------------------------------
# Dashboard → Project Settings → API
#   URL:          https://supabase.com/dashboard/project/xdxzxyzdgwpucwuaxvik/settings/api
#   Anon key:     idem (seção "Project API keys")
# ======================================================================
EXPO_PUBLIC_SUPABASE_URL=https://xdxzxyzdgwpucwuaxvik.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...


# ======================================================================
# 2. Mapbox — cliente, motorista, admin
# ----------------------------------------------------------------------
# Token público restrito por URL (não é secret):
#   https://account.mapbox.com/access-tokens/
# Se mudar este valor, reste o Metro (--clear) e, no motorista, rode
# `npx expo prebuild --clean` porque o token entra no AndroidManifest.
# ======================================================================
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...


# ======================================================================
# 3. Google Maps (Places + Geocoding) — cliente, motorista, admin
# ----------------------------------------------------------------------
# Cloud Console → APIs & Services → Credentials:
#   https://console.cloud.google.com/apis/credentials
# Habilitar "Places API" e "Geocoding API"; restringir por referrer/app.
# Usado em sugestões de endereço e geocoding de rotas salvas.
# ======================================================================
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...


# ======================================================================
# 4. Stripe (tokenização no cliente) — SÓ o app cliente usa
# ----------------------------------------------------------------------
# Chave PÚBLICA (pk_test_... em dev, pk_live_... em produção):
#   https://dashboard.stripe.com/apikeys
# A secret (sk_*) NÃO vai aqui — vive nos secrets do Supabase
# (seção 7 deste arquivo) porque só as Edge Functions a usam.
# ======================================================================
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...


# ======================================================================
# 5. Deep link scheme — SÓ o app cliente
# ----------------------------------------------------------------------
# Usado no fluxo de recuperação de senha para abrir o app via URL.
# O motorista usa o scheme `takeme` hard-coded em app.json (não precisa
# de variável) nos deep links de retorno do Stripe Connect.
# ======================================================================
EXPO_PUBLIC_APP_SCHEME=take-me-cliente


# ======================================================================
# 6. Playwright E2E — SÓ o app admin (opcional)
# ----------------------------------------------------------------------
# Credenciais de um usuário com app_metadata.role = admin.
# Sem estas variáveis os testes autenticados são ignorados (skip).
# ======================================================================
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_REQUIRE_DB_ROWS=1   # opcional: falha se as tabelas principais estão vazias


# ======================================================================
# 7. Scripts Node locais (scripts/*.js) — NÃO vai no bundle
# ----------------------------------------------------------------------
# service_role key é SECRETA. Usada apenas em scripts rodando no seu
# computador (ex.: create-avatars-bucket.js, delete-user-by-email.js).
# Nunca reference como EXPO_PUBLIC_*.
#   https://supabase.com/dashboard/project/xdxzxyzdgwpucwuaxvik/settings/api
# ======================================================================
# SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ======================================================================
# 8. Supabase Edge Functions — NÃO COLOCAR AQUI
# ----------------------------------------------------------------------
# Os secrets abaixo vivem no Supabase, não no .env do projeto. Já estão
# configurados no projeto `xdxzxyzdgwpucwuaxvik` (validado em 21/abr/2026).
# Para ver/editar:
#   https://supabase.com/dashboard/project/xdxzxyzdgwpucwuaxvik/functions/secrets
# Ou via CLI:
#   npx supabase secrets set CHAVE=valor --project-ref xdxzxyzdgwpucwuaxvik
#
# Lista de secrets usados pelas Edge Functions (referência):
#   - STRIPE_SECRET_KEY            (sk_test_... ou sk_live_...)
#   - STRIPE_WEBHOOK_SECRET        (whsec_... — um por endpoint no Dashboard Stripe)
#   - STRIPE_CONNECT_RETURN_URL    (opcional; cliente envia no body)
#   - STRIPE_CONNECT_REFRESH_URL   (opcional; cliente envia no body)
#   - RESEND_API_KEY               (re_... — emails transacionais)
#   - RESEND_FROM_EMAIL            (ex.: contato@takeme.app)
# ======================================================================
