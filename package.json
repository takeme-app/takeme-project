{
  "name": "take-me",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "cliente": "npm run start --workspace=cliente",
    "motorista": "npm run start --workspace=motorista",
    "preparador-encomendas": "npm run start --workspace=preparador-encomendas",
    "preparador-excursoes": "npm run start --workspace=preparador-excursoes",
    "admin": "npm run start --workspace=admin",
    "deploy:verify-email-code": "npx supabase functions deploy verify-email-code --no-verify-jwt",
    "create-avatars-bucket":"node scripts/create-avatars-bucket.js","db:push":"supabase db push","deploy:functions": "npx supabase functions deploy send-email-verification-code --no-verify-jwt && npx supabase functions deploy verify-email-code --no-verify-jwt && npx supabase functions deploy send-welcome-email --no-verify-jwt"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "supabase": "^2.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "tar": "^7.5.8"
  }
}
