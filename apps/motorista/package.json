{
  "name": "motorista",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),path=require('path');const r=path.resolve(__dirname,'../../.env');const d=path.resolve(__dirname,'.env');if(fs.existsSync(r))fs.copyFileSync(r,d);\"",
    "motorista": "npm run motorista --prefix ../..",
    "motorista:ios": "npm run motorista:ios --prefix ../..",
    "motorista:android": "npm run motorista:android --prefix ../..",
    "build:apk": "node scripts/build-apk.js",
    "motorista:apk": "npm run motorista:apk --prefix ../..",
    "start": "expo start --port 8082",
    "start:lan": "node -e \"const fs=require('fs'),path=require('path');const r=path.resolve(__dirname,'../../.env');const d=path.resolve(__dirname,'.env');if(fs.existsSync(r))fs.copyFileSync(r,d);\" && expo start --port 8082 --host lan",
    "native:ios": "expo run:ios",
    "native:android": "node scripts/expo-android.js",
    "android": "node scripts/expo-android.js",
    "android:run": "node scripts/expo-android.js --no-bundler",
    "android:reverse": "node scripts/adb-reverse.js",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@rnmapbox/maps": "^10.2.10",
    "@take-me/shared": "*",
    "expo": "^54.0.33",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.14.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~18.0.4",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
