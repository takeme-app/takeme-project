{
  "expo": {
    "name": "Take Me - Motorista",
    "slug": "take-me-motorista",
    "owner": "fraktal-softwares",
    "scheme": "take-me-motorista",
    "version": "1.0.0",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.takeme.motorista",
      "supportsTablet": true
    },
    "android": {
      "package": "com.takeme.motorista",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "backgroundColor": "#000000",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Take Me Motorista usa sua localização para exibir sua posição e corridas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para enviar documentos e fotos do veículo."
        }
      ]
    ]
  }
}
