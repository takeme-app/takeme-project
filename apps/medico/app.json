{
  "expo": {
    "name": "Take Me - Médico",
    "slug": "take-me-medico",
    "owner": "fraktal-softwares",
    "scheme": "take-me-medico",
    "version": "1.0.0",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.takeme.medico",
      "supportsTablet": true
    },
    "android": {
      "package": "com.takeme.medico",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": { "bundler": "metro" },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "backgroundColor": "#000000",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
