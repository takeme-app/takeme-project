{
  "expo": {
    "name": "Take Me - Cliente",
    "slug": "take-me-cliente",
    "scheme": "take-me-cliente",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.takeme.cliente",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d68908f6-df27-457e-86f0-fa952777a0b6"
      }
    },
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Take Me usa sua localização para definir o ponto de partida e mostrar motoristas próximos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para alterar a foto de perfil."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.takeme.cliente"
        }
      ],
      "expo-web-browser"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d68908f6-df27-457e-86f0-fa952777a0b6"
    }
  }
}
