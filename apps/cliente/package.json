  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),path=require('path');const r=path.resolve(__dirname,'../../.env');const d=path.resolve(__dirname,'.env');if(fs.existsSync(r))fs.copyFileSync(r,d);\"",
    "start": "expo start --port 8085",
    "start:8081": "expo start --port 8081",
    "android": "node scripts/run-android.js",
    "android:run": "node scripts/run-android-dev.js",
    "android:reverse": "node scripts/adb-reverse.js",
    "android:release": "node scripts/build-release-apk.js",
