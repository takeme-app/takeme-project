# Copiar para `.env` e preencher (não commitar `.env`).
# Supabase (já usado pelo Expo)
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox — mapa estático/interativo nas telas de viagem (token público restrito por URL).
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Google Maps — sugestões de endereço (Places) + geocoding ao salvar / fallback no mapa.
# Ative "Places API" e "Geocoding API" no Google Cloud; restrinja por referrer HTTP.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Playwright — utilizador com app_metadata.role = admin
# Sem estas variáveis, os testes autenticados são ignorados (skip).
# Nomes exatos (sem espaços antes do =):
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Opcional: exige pelo menos uma linha nas tabelas principais (falha se a BD estiver vazia).
# E2E_REQUIRE_DB_ROWS=1
# Alternativa: as mesmas chaves no `.env` na raiz do monorepo.
